{
  "templateId": 101,
  "reportId": 5001,

  "queries": {
    "scenarios": {
      "queryKey": "GET_SCENARIOS",
      "returns": "LIST"
    },
    "placeholders": {
      "queryKey": "GET_PLACEHOLDERS",
      "returns": "MAP"
    }
  },

  "sheets": [
    {
      "sourceSheetName": "Across Cycles_Citigroup",
      "outputSheetName": "Across_cycle_scenarios",

      "staticColumns": {
        "columns": ["A", "B"],
        "dataSourceKey": "GET_LINE_ITEMS",
