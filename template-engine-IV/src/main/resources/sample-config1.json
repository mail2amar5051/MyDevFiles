          { "column": "B", "dbColumn": "form_line_name" },
          { "column": "C", "dbColumn": "baseline_14q" }
        ]
      },

      "directMappings": {
        "headerRow": 4,
        "startRow": 5,
        "dataSourceKey": "GET_QVA_DATA",
        "rowKey": "line_id",
        "columns": [
