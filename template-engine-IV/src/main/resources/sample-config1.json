        "mappings": [
          { "column": "A", "dbColumn": "line_id" },
          { "column": "B", "dbColumn": "form_line_name" }
        ]
      },

      "cloneBlock": {
        "columns": "C:Y",
        "repeatForEach": "scenarios",
        "scenarioNamePlaceholder": "{{scenarioname}}",
        "scenarioNameField": "scenarioName"
      },

      "dataRows": {
        "headerRow": 5,
        "startRow": 6,
        "dataSourceKey": "GET_SCENARIO_DATA",
        "rowKey": "line_id",
        "scenarioKey": "scenario_name",

        "blockMappings": [
