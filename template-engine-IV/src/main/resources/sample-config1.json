          { "offset": 8,  "dbColumn": "curr_pq8" },
          { "offset": 9,  "dbColumn": "curr_pq9" },
          { "offset": 11, "dbColumn": "prior_pq1" },
          { "offset": 12, "dbColumn": "prior_pq2" },
          { "offset": 13, "dbColumn": "prior_pq3" },
          { "offset": 14, "dbColumn": "prior_pq4" },
          { "offset": 15, "dbColumn": "prior_pq5" },
          { "offset": 16, "dbColumn": "prior_pq6" },
          { "offset": 17, "dbColumn": "prior_pq7" },
          { "offset": 18, "dbColumn": "prior_pq8" },
          { "offset": 19, "dbColumn": "prior_pq9" }
        ]
      },

      "conditionalStyles": [
        {
          "offsets": [21, 22],
          "description": "Red fill + black font for negative comparison values",
          "condition": "LESS_THAN",
          "value": 0,
          "style": {
            "fillColor": "FF0000",
            "fontColor": "000000"
          }
        }
      ],
      "conditionalStyles": [
        {
          "priority": 1,
          "offsets": [21, 22],
          "description": "Red fill for negative comparison values",
          "condition": "LESS_THAN",
          "value": 0,
          "style": { "fillColor": "FF0000", "fontColor": "000000" }
        }
      ],

      "commonPlaceholders": "placeholders",

      "preserve": [
        "mergedRegions",
        "formulas",
        "styles",
        "columnWidths"
      ]
    },
    {
      "sourceSheetName": "Q vs A_Citigroup",
      "outputSheetName": "Q vs A_Citigroup",

      "staticColumns": {
        "columns": ["A", "B", "C"],
        "dataSourceKey": "GET_QVA_LINE_ITEMS",
        "startRow": 5,
